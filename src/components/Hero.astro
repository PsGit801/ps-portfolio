---
import { profile, socials } from '../data/resume';
---

<section id="top" class="hero">
  <div class="container">
    <p class="hero__role eyebrow">{profile.role}</p>
    <h1 class="hero__name">{profile.name}</h1>
    <p class="hero__tagline">{profile.tagline}</p>
    <p class="hero__location">{profile.location}</p>

    <div class="hero__actions">
      <a class="btn btn--primary" href={`mailto:${profile.email}`}>Get in touch</a>
      <a class="btn" href={profile.resumeUrl} target="_blank" rel="noopener">Download résumé</a>
    </div>

    <ul class="hero__socials">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} target={s.label === 'Email' ? undefined : '_blank'} rel="noopener">
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6rem);
    background:
      radial-gradient(60% 120% at 100% 0%, var(--accent-soft), transparent 60%),
      var(--bg);
  }
  .hero__role {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }
  .hero__name {
    font-size: clamp(2.4rem, 7vw, 3.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 700;
  }
  .hero__tagline {
    font-size: clamp(1.1rem, 3vw, 1.4rem);
    color: var(--text-muted);
    margin-top: 0.9rem;
    max-width: 34ch;
  }
  .hero__location {
    color: var(--text-muted);
    margin-top: 0.4rem;
    font-size: 0.95rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  .hero__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.75rem;
    font-size: 0.92rem;
  }
  .hero__socials a {
    color: var(--text-muted);
  }
  .hero__socials a:hover {
    color: var(--accent);
  }
</style>
