---
import { profile, socials } from '../data/resume';
const year = 2026;
---

<footer class="footer">
  <div class="container footer__inner">
    <p>© {year} {profile.name}</p>
    <ul class="footer__links">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} target={s.label === 'Email' ? undefined : '_blank'} rel="noopener">
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
    <p class="footer__built">Built with Astro</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-subtle);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding-block: 2rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .footer__links {
    display: flex;
    gap: 1.25rem;
    margin-right: auto;
  }
  .footer__links a {
    color: var(--text-muted);
  }
  .footer__links a:hover {
    color: var(--accent);
  }
  .footer__built {
    opacity: 0.8;
  }
  @media (max-width: 520px) {
    .footer__links {
      order: 3;
      width: 100%;
      margin-right: 0;
    }
  }
</style>
