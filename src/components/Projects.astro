---
import { projects } from '../data/resume';
---

<section id="projects" class="section bg-aurora">
  <div class="container section-split">
    <h2 class="section-title reveal">Projects</h2>
    <div class="grid">
      {
        projects.map((p) => (
          <article class="card reveal">
            {p.image && (
              <div class="card__media">
                <img
                  src={p.image}
                  alt={p.imageAlt}
                  width="846"
                  height="630"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            )}
            <header class="card__head">
              <h3 class="card__title">{p.name}</h3>
            </header>
            <p class="card__blurb">{p.blurb}</p>
            <ul class="card__points">
              {p.points.map((pt) => <li>{pt}</li>)}
            </ul>
            <ul class="card__tags">
              {p.tags.map((t) => (
                <li class="chip">{t}</li>
              ))}
            </ul>
            {p.links && p.links.length > 0 && (
              <div class="card__links">
                {p.links.map((l) => (
                  <a class="card__link" href={l.href} target="_blank" rel="noopener">
                    {l.label} <span aria-hidden="true">↗</span>
                  </a>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: transform 0.12s ease, border-color 0.15s ease;
  }
  .card__media {
    margin: -1.5rem -1.5rem 0.4rem;
    border-bottom: 1px solid var(--border);
    background: #fff;
  }
  .card__media img {
    display: block;
    width: 100%;
    height: auto;
  }
  .card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }
  .card__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }
  .card__blurb {
    color: var(--text);
  }
  .card__points {
    display: grid;
    gap: 0.45rem;
    font-size: 0.92rem;
  }
  .card__points li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-muted);
  }
  .card__points li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding-top: 0.85rem;
    margin-top: 0.85rem;
    border-top: 1px solid var(--border);
  }
  .card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--accent);
  }
  .card__link:hover {
    text-decoration: none;
    gap: 0.55rem;
  }
  .card__link span {
    transition: transform 0.15s var(--ease);
  }
  .card__link:hover span {
    transform: translate(2px, -2px);
  }
</style>
