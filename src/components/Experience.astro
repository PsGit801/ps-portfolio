---
import { experience } from '../data/resume';
---

<section id="experience" class="section">
  <div class="container section-split">
    <h2 class="section-title reveal">Experience</h2>
    <ol class="timeline">
      {
        experience.map((job) => (
          <li class="job reveal">
            <div class="job__head">
              <h3 class="job__role">
                {job.role} <span class="job__company">· {job.company}</span>
              </h3>
              <p class="job__meta">
                <span>{job.period}</span>
                <span aria-hidden="true">·</span>
                <span>{job.location}</span>
              </p>
            </div>
            <ul class="job__points">
              {job.points.map((p) => <li>{p}</li>)}
            </ul>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    display: grid;
    gap: 2.25rem;
  }
  .job {
    display: grid;
    gap: 0.85rem;
  }
  .job__role {
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .job__company {
    color: var(--text-muted);
    font-weight: 500;
  }
  .job__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.2rem;
  }
  .job__points {
    display: grid;
    gap: 0.55rem;
    color: var(--text);
    max-width: 68ch;
  }
  .job__points li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--text-muted);
  }
  .job__points li::before {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.68em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }
</style>
