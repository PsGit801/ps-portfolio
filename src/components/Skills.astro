---
import { skills } from '../data/resume';
---

<section id="skills" class="section tech-grid">
  <div class="container section-split">
    <h2 class="section-title reveal">Skills</h2>
    <div class="skills">
      {
        skills.map((s) => (
          <div class="skills__group reveal">
            <h3 class="skills__label">{s.group}</h3>
            <ul class="skills__list">
              {s.items.map((item) => (
                <li class="chip">{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.75rem 2.5rem;
  }
  @media (max-width: 560px) {
    .skills {
      grid-template-columns: 1fr;
    }
  }
  .skills__label {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .skills__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
